{
  "info": {
    "_postman_id": "4d6d18c5-2a2b-4c6f-b54e-9c43d95e8aaf",
    "name": "Ruprecht Auth API",
    "description": "Colección para probar autenticación de Ruprecht. Importa este archivo en Postman y ejecuta Login para guardar automáticamente el token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Register",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"usuario{{$timestamp}}@mail.com\",\n  \"contrasena\": \"{{testPassword}}\",\n  \"rol\": \"admin\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        },
        "description": "Registra un usuario nuevo. Usa body JSON (no Params)."
      },
      "response": []
    },
    {
      "name": "Auth - Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "let data = {};",
              "try { data = pm.response.json(); } catch (e) {}",
              "if (pm.response.code === 200 && data.token) {",
              "  pm.collectionVariables.set('token', data.token);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{testEmail}}\",\n  \"contrasena\": \"{{testPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        },
        "description": "Inicia sesión y guarda el token en la variable de colección token."
      },
      "response": []
    },
    {
      "name": "Auth - Me",
      "request": {
        "method": "GET",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/me",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "me"
          ]
        },
        "description": "Obtiene el usuario autenticado usando el token guardado."
      },
      "response": []
    },
    {
      "name": "Auth - Logout",
      "request": {
        "method": "POST",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/logout",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "logout"
          ]
        },
        "description": "Cierra sesión del usuario autenticado."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3333"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "testEmail",
      "value": "admin@ruprecht.com"
    },
    {
      "key": "testPassword",
      "value": "12345678"
    }
  ]
}
